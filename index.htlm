<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>PurpleDrop Pro</title>
    <script src="https://unpkg.com"></script>
    <style>
        :root { --p: #a855f7; --bg: #0b0e14; --w: #ffffff; --glass: rgba(30, 41, 59, 0.8); }
        body { margin: 0; background: var(--bg); color: var(--w); font-family: -apple-system, sans-serif; overflow: hidden; height: 100vh; }
        
        /* Pantalla de Inicio (Splash) */
        #splash { position: fixed; inset: 0; background: var(--bg); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 1000; transition: 0.8s; }
        .octocat { 
            width: 100px; height: 100px; 
            background: url('https://github.githubassets.com') no-repeat center/contain;
            filter: invert(45%) sepia(93%) saturate(1450%) hue-rotate(245deg);
            animation: pulse 2s infinite;
        }
        @keyframes pulse { 0%, 100% { transform: scale(1); opacity: 0.7; } 50% { transform: scale(1.1); opacity: 1; } }

        /* Chat y Animación de Choque */
        #chat { height: 100vh; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 15px; padding-bottom: 180px; box-sizing: border-box; }
        .msg { 
            padding: 14px; border-radius: 20px; max-width: 75%; 
            animation: clash 0.5s cubic-bezier(0.18, 0.89, 0.32, 1.28);
            border: 1px solid rgba(168, 85, 247, 0.2);
        }
        @keyframes clash { 0% { transform: translateY(40px) scale(0.8); opacity: 0; } 100% { transform: translateY(0) scale(1); opacity: 1; } }
        .sent { align-self: flex-end; background: var(--p); box-shadow: 0 4px 20px rgba(168, 85, 247, 0.3); }
        .received { align-self: flex-start; background: #1e293b; }

        /* Controles Inferiores */
        .controls { position: fixed; bottom: 0; width: 100%; background: var(--glass); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); padding: 20px; box-sizing: border-box; border-top: 1px solid rgba(168, 85, 247, 0.3); border-radius: 25px 25px 0 0; }
        .row { display: flex; gap: 10px; align-items: center; }
        input { background: rgba(255,255,255,0.05); border: 1px solid var(--p); color: #fff; padding: 12px; border-radius: 15px; outline: none; }
        .btn-send { background: var(--p); border: none; color: white; border-radius: 50%; width: 45px; height: 45px; font-size: 20px; }

        #big-emoji { position: fixed; top: 40%; left: 50%; transform: translate(-50%, -50%); font-size: 150px; opacity: 0; pointer-events: none; transition: 0.5s; z-index: 900; }
        .emoji-show { opacity: 0.5 !important; transform: translate(-50%, -50%) scale(1.4) !important; }
        .media { width: 100%; border-radius: 12px; margin-top: 5px; }
    </style>
</head>
<body onclick="hideSplash()">

<div id="splash">
    <div class="octocat"></div>
    <h2 style="color: var(--p); letter-spacing: 3px; margin-top: 20px;">PURPLE DROP</h2>
    <p style="opacity: 0.5; font-size: 12px;">TOCA PARA INICIAR</p>
</div>

<div id="big-emoji">❤️</div>
<div id="chat"></div>

<div class="controls">
    <div id="status" style="font-size: 11px; color: var(--p); margin-bottom: 8px;">CONECTANDO...</div>
    <div class="row">
        <button onclick="document.getElementById('file-in').click()" style="background:none; border:1px solid var(--p); color:var(--p); border-radius:50%; width:40px; height:40px;">+</button>
        <input type="file" id="file-in" hidden accept="image/*,video/*" onchange="sendMedia(event)">
        <input type="number" id="target-id" placeholder="ID" style="width: 50px;">
        <input type="text" id="msg-in" placeholder="Mensaje..." style="flex:1;">
        <button class="btn-send" onclick="sendText()">↑</button>
    </div>
</div>

<script>
    let peer, myPin;
    const chat = document.getElementById('chat');

    function hideSplash() {
        document.getElementById('splash').style.opacity = '0';
        setTimeout(() => document.getElementById('splash').style.display = 'none', 800);
    }

    myPin = localStorage.getItem('pdrop_pin') || Math.floor(1000 + Math.random() * 9000).toString();
    localStorage.setItem('pdrop_pin', myPin);
    document.getElementById('status').innerText = "TU ID: " + myPin;

    peer = new Peer('pdrop-' + myPin);

    peer.on('connection', conn => {
        conn.on('data', data => render(data.content, 'received', data.type));
    });

    function sendText() {
        const tid = document.getElementById('target-id').value;
        const txt = document.getElementById('msg-in').value;
        if (!tid || !txt) return;
        const conn = peer.connect('pdrop-' + tid);
        conn.on('open', () => {
            conn.send({ content: txt, type: 'text' });
            render(txt, 'sent', 'text');
            document.getElementById('msg-in').value = '';
        });
    }

    function sendMedia(e) {
        const tid = document.getElementById('target-id').value;
        const file = e.target.files[0];
        if (!tid || !file) return;
        const reader = new FileReader();
        reader.onload = () => {
            const conn = peer.connect('pdrop-' + tid);
            conn.on('open', () => {
                const type = file.type.startsWith('image') ? 'img' : 'vid';
                conn.send({ content: reader.result, type: type });
                render(reader.result, 'sent', type);
            });
        };
        reader.readAsDataURL(file);
    }

    function render(data, side, type) {
        const d = document.createElement('div');
        d.className = `msg ${side}`;
        if (type === 'text') {
            d.innerText = data;
            if (["❤️","😍","🔥"].some(e => data.includes(e))) {
                const b = document.getElementById('big-emoji');
                b.innerText = data; b.classList.add('emoji-show');
                setTimeout(() => b.classList.remove('emoji-show'), 1200);
            }
        } else if (type === 'img') {
            d.innerHTML = `<img src="${data}" class="media">`;
        } else {
            d.innerHTML = `<video src="${data}" class="media" controls></video>`;
        }
        chat.appendChild(d);
        chat.scrollTop = chat.scrollHeight;
    }
</script>
</body>
</html>
