<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>PurpleDrop Pro</title>
    <!-- Librería para conexión directa entre teléfonos -->
    <script src="https://unpkg.com"></script>
    <style>
        :root { --p: #a855f7; --bg: #0b0e14; --w: #ffffff; --glass: rgba(30, 41, 59, 0.8); }
        
        body { 
            margin: 0; background: var(--bg); color: var(--w); 
            font-family: -apple-system, BlinkMacSystemFont, sans-serif; 
            overflow: hidden; height: 100vh;
        }

        /* Splash Screen - Logo GitHub Morado */
        #splash {
            position: fixed; inset: 0; background: var(--bg);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            z-index: 1000; transition: 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .octocat {
            width: 120px; height: 120px;
            background: url('https://github.githubassets.com') no-repeat center/contain;
            filter: invert(45%) sepia(93%) saturate(1450%) hue-rotate(245deg);
            animation: pulse 2s infinite;
        }
        @keyframes pulse { 0%, 100% { transform: scale(1); opacity: 0.7; } 50% { transform: scale(1.1); opacity: 1; } }

        /* Contenedor de Chat */
        #chat { 
            height: 100vh; overflow-y: auto; padding: 20px; 
            display: flex; flex-direction: column; gap: 15px;
            padding-bottom: 180px; box-sizing: border-box;
        }
        
        /* Animación de Choque */
        .msg { 
            padding: 14px; border-radius: 20px; max-width: 75%; 
            animation: clash 0.5s cubic-bezier(0.18, 0.89, 0.32, 1.28);
            border: 1px solid rgba(168, 85, 247, 0.2);
            font-size: 15px; line-height: 1.4;
        }
        @keyframes clash { 
            0% { transform: translateY(40px) scale(0.8); opacity: 0; }
            100% { transform: translateY(0) scale(1); opacity: 1; }
        }
        .sent { align-self: flex-end; background: var(--p); box-shadow: 0 4px 20px rgba(168, 85, 247, 0.3); }
        .received { align-self: flex-start; background: #1e293b; }

        /* Multimedia */
        .media-content { width: 100%; border-radius: 12px; margin-top: 5px; display: block; }
        
        /* Controles Inferiores Futuristas */
        .controls { 
            position: fixed; bottom: 0; width: 100%; 
            background: var(--glass); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            padding: 20px; box-sizing: border-box;
            border-top: 1px solid rgba(168, 85, 247, 0.3);
            border-radius: 25px 25px 0 0;
        }
        .row { display: flex; gap: 10px; align-items: center; }
        
        input, input[type="number"] { 
            background: rgba(255,255,255,0.05); border: 1px solid var(--p); 
            color: #fff; padding: 12px; border-radius: 15px; outline: none;
        }
        
        .btn-round { 
            background: var(--p); border: none; color: white; 
            border-radius: 50%; width: 45px; height: 45px; 
            font-size: 20px; cursor: pointer; display: flex; align-items: center; justify-content: center;
        }

        #big-emoji { 
            position: fixed; top: 40%; left: 50%; transform: translate(-50%, -50%); 
            font-size: 160px; opacity: 0; pointer-events: none; transition: 0.5s; z-index: 900; 
        }
        .emoji-show { opacity: 0.5 !important; transform: translate(-50%, -50%) scale(1.4) !important; }
    </style>
</head>
<body onclick="hideSplash()">

<div id="splash">
    <div class="octocat"></div>
    <h2 style="color: var(--p); letter-spacing: 3px; margin-top: 20px;">PURPLE DROP</h2>
    <p style="opacity: 0.5; font-size: 12px;">TOCA PARA INICIAR</p>
</div>

<div id="big-emoji">❤️</div>

<div id="chat"></div>

<div class="controls">
    <div id="status" style="font-size: 11px; color: var(--p); margin-bottom: 8px; font-weight: bold;">BUSCANDO RED...</div>
    <div class="row">
        <button class="btn-round" onclick="document.getElementById('file-in').click()" style="background: transparent; border: 1px solid var(--p);">+</button>
        <input type="file" id="file-in" hidden accept="image/*,video/*" onchange="handlePreview(event)">
        <input type="number" id="target-id" placeholder="ID" style="width: 55px; text-align: center;">
        <input type="text" id="msg-in" placeholder="Escribe un mensaje...">
        <button class="btn-round" onclick="send()">↑</button>
    </div>
</div>

<script>
    let peer, myPin;
    const chat = document.getElementById('chat');

    function hideSplash() {
        document.getElementById('splash').style.opacity = '0';
        setTimeout(() => document.getElementById('splash').style.display = 'none', 800);
    }

    // Configuración de ID y Conexión
    myPin = localStorage.getItem('pdrop_pin') || Math.floor(1000 + Math.random() * 9000).toString();
    localStorage.setItem('pdrop_pin', myPin);
    document.getElementById('status').innerText = "TU ID: " + myPin;

    peer = new Peer('pdrop-' + myPin);

    // Cargar historial del teléfono
    window.onload = () => {
        const history = JSON.parse(localStorage.getItem('pdrop_history') || '[]');
        history.forEach(m => renderMsg(m.data, m.type, m.fileType));
    };

    // Escuchar mensajes entrantes
    peer.on('connection', conn => {
        conn.on('data', data => {
            saveAndShow(data.content, 'received', data.fileType);
        });
    });

    function send() {
        const tid = document.getElementById('target-id').value;
        const txt = document.getElementById('msg-in').value;
        const fileInput = document.getElementById('file-in');

        if (!tid) return alert("Ingresa el ID de 4 dígitos");

        const conn = peer.connect('pdrop-' + tid);
        conn.on('open', () => {
            if (fileInput.files.length > 0) {
                const file = fileInput.files[0];
                const reader = new FileReader();
                reader.onload = () => {
                    const data = { content: reader.result, fileType: file.type };
                    conn.send(data);
                    saveAndShow(data.content, 'sent', data.fileType);
                    fileInput.value = ""; 
                };
                reader.readAsDataURL(file);
            } else if (txt) {
                conn.send({ content: txt, fileType: 'text' });
                saveAndShow(txt, 'sent', 'text');
                document.getElementById('msg-in').value = '';
            }
        });
    }

    function saveAndShow(data, type, fileType) {
        const history = JSON.parse(localStorage.getItem('pdrop_history') || '[]');
        history.push({ data, type, fileType });
        localStorage.setItem('pdrop_history', JSON.stringify(history));
        renderMsg(data, type, fileType);
        
        // Animación Emoji
        if (fileType === 'text' && ["❤️","😍","🔥","😘"].some(e => data.includes(e))) {
            const b = document.getElementById('big-emoji');
            b.innerText = data; b.classList.add('emoji-show');
            setTimeout(() => b.classList.remove('emoji-show'), 1200);
        }
    }

    function renderMsg(data, type, fileType) {
        const d = document.createElement('div');
        d.className = `msg ${type}`;
        if (fileType === 'text') {
            d.innerText = data;
        } else if (fileType.startsWith('image')) {
            d.innerHTML = `<img src="${data}" class="media-content">`;
        } else if (fileType.startsWith('video')) {
            d.innerHTML = `<video src="${data}" class="media-content" controls></video>`;
        }
        chat.appendChild(d);
        chat.scrollTop = chat.scrollHeight;
    }
</script>
</body>
</html>
